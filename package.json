{
  "name": "opencrawdio-monorepo",
  "private": true,
  "packageManager": "pnpm@8.5.1",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage --",
    "dev": "turbo run dev --filter=opencrawdio",
    "dev:tui": "turbo run dev:tui --filter=opencrawdio",
    "start": "turbo run start --filter=opencrawdio",
    "start:tui": "turbo run start:tui --filter=opencrawdio"
  },
  "devDependencies": {
    "turbo": "^2.9.6"
  }
}
