{
  "name": "opencrawdio",
  "version": "1.0.0",
  "description": "",
  "main": "dist/src/index.js",
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:tui": "tsx watch src/index.ts --tui",
    "clean": "rm -rf dist",
    "build": "pnpm run clean && tsc --project tsconfig.json",
    "start": "node dist/src/index.js",
    "start:tui": "node dist/src/index.js --tui",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guilhermesalviano/opencrawdio.git"
  },
  "keywords": [],
  "author": "guilhermesalviano",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/guilhermesalviano/opencrawdio/issues"
  },
  "homepage": "https://github.com/guilhermesalviano/opencrawdio#readme",
  "dependencies": {
    "dotenv": "^17.4.1",
    "readline": "^1.3.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "4.1.3",
    "@vitest/ui": "^4.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
