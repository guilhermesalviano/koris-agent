# Ensure consistent line endings across platforms
* text=auto

# Lock files must use LF (not CRLF)
pnpm-lock.yaml text eol=lf
package-lock.json text eol=lf
yarn.lock text eol=lf

# Shell scripts must use LF
*.sh text eol=lf
*.bash text eol=lf

# YAML files must use LF
*.yaml text eol=lf
*.yml text eol=lf

# TypeScript/JavaScript
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf

# Markdown
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
