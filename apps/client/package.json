{
  "name": "opencrawdio",
  "version": "1.0.0",
  "description": "",
  "main": "dist/src/app.js",
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev:server": "tsx watch src/channels/web/index.ts",
    "server": "node dist/src/channels/web/index.js",
    "app": "node dist/src/app.js",
    "clean": "rm -rf dist",
    "build": "pnpm run clean && tsc --project tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guilhermesalviano/opencrawdio.git"
  },
