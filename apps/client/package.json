  "license": "ISC",
  "bugs": {
    "url": "https://github.com/guilhermesalviano/opencrawdio/issues"
  },
  "homepage": "https://github.com/guilhermesalviano/opencrawdio#readme",
  "dependencies": {
    "assistant-telegram-bot": "workspace:*",
    "assistant-tui": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "p-limit": "^7.3.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/ui": "^4.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
