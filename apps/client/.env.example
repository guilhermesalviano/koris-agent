# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# AI Provider Configuration
# Supported: ollama, mock
AI_PROVIDER=ollama

# AI Configuration
# Base URL for AI API
AI_BASE_URL=http://localhost:11434

# AI model to use
AI_MODEL=gemma4:e2b
